# Discord application (developer portal -> your app -> Bot / OAuth2)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Postgres. Needs the asyncpg driver, e.g.:
# postgresql+asyncpg://user:password@host:5432/reaper
DATABASE_URL=

# Random secret for signing the admin-UI session cookie, e.g. `openssl rand -hex 32`
SESSION_SECRET_KEY=
SESSION_MAX_AGE_SECONDS=10800

# Comma-separated Discord user IDs that bypass per-guild admin-UI checks for
# support/debug only (spec 3.2) -- never a normal user-facing path.
BOT_SUPERADMIN_IDS=

# Module 1 defaults, per-guild overrides live in the Guild table via /reaper config
DEFAULT_BURST_WINDOW_SECONDS=60
DEFAULT_BURST_CHANNEL_THRESHOLD=3
DEFAULT_TIMEOUT_SECONDS=3600
SCAM_IMAGE_HAMMING_THRESHOLD=10

# /reaper roast (mod-only). Leave ANTHROPIC_API_KEY unset to disable the command.
ANTHROPIC_API_KEY=
ROAST_MODEL=claude-haiku-4-5
ROAST_MAX_MESSAGES=25
ROAST_CHANNEL_SCAN_LIMIT=300
